# Example only. Copy to .env and edit locally. Do NOT commit .env.
# Canonical local default: if DB_URL is omitted, the repo uses <SCIENCIAAI_DATA_DIR>/ingestion.db.
# scripts/init_db.py follows this same convention so future schema work should not assume a different local DB path.
SCIENCIAAI_DATA_DIR=.local/scienciaai
# Optional absolute SQLite override examples:
# macOS/Linux: DB_URL=sqlite:////absolute/path/to/ingestion.db
# Windows:     DB_URL=sqlite:///C:/absolute/path/to/ingestion.db
